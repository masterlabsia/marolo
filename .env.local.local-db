# Variáveis para desenvolvimento local com Supabase CLI
# Copie este arquivo para .env.local quando quiser usar o banco local
# Depois rode: npm run db:start

# Estas URLs são sempre as mesmas no Supabase local
VITE_SUPABASE_URL=http://localhost:54321

# Rode `npm run db:status` para obter a anon key gerada na sua máquina
# e substitua abaixo:
VITE_SUPABASE_ANON_KEY=COLE_AQUI_A_ANON_KEY_DO_db:status
